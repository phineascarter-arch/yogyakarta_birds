function sciNameOf(name){ return SCI[name] || ""; }

/* ---------------- 依關鍵字給小知識 ---------------- */
function fieldNote(name){
  const rules = [
    [/鷸|Sandpiper|Godwit|Curlew|Stint|Snipe|Tattler|Dowitcher/i, "岸鳥：長喙探入泥灘覓食，退潮時最容易大量出現。"],
    [/鷺|Heron|Egret|Bittern/i, "鷺科：涉水靜立伺機獵食魚蝦，留意頸部瞬間伸縮的動作。"],
    [/鴴|Plover/i, "鴴科：短喙圓頭，「奔跑—啄食—停頓」是牠們覓食的招牌節奏。"],
    [/燕鷗|Tern|軍艦鳥|Frigatebird/i, "海鳥：飛行中俯衝入水捕魚，注意尾羽開叉與翼形。"],
    [/鵯|Bulbul/i, "鵯科：群棲吵鬧，常常先聞其聲、再見其影。"],
    [/鶲|Flycatcher/i, "鶲科：定點停棲，飛出捕蟲後常返回同一枝頭。"],
    [/啄木鳥|Woodpecker|擬啄木鳥|Barbet|Piculet|Flameback/i, "啄木鳥／擬啄木科：先聽敲擊聲，往往比用眼睛找更快。"],
    [/鷹|Eagle|鵟|Falcon|隼|鵰|Kite|Kestrel|Goshawk|Sparrowhawk/i, "猛禽：留意翱翔輪廓與翼形，先用望遠鏡掃視天空。"],
    [/鳩|鴿|Dove|Pigeon/i, "鳩鴿科：注意頸羽花紋與獨特的叫聲節奏。"],
    [/燕|Swallow|Swift|雨燕|金絲燕|Swiftlet|Needletail|Treeswift/i, "燕／雨燕科：飛行中捕食昆蟲，觀察飛行軌跡與尾叉。"],
    [/文鳥|Munia|Weaver|雀|Sparrow|Avadavat|Parrotfinch/i, "梅花雀／文鳥科：常成群活動於草地、農田或蘆葦叢。"],
    [/翡翠|Kingfisher/i, "翠鳥科：水邊枝頭定點守候，俯衝入水捕魚。"],
    [/鶇|Thrush/i, "鶇科：常在地面翻找落葉層覓食，動作沉穩。"],
    [/伯勞|Shrike/i, "伯勞科：性凶猛，常停在顯眼枝頭俯視獵物。"],
    [/花蜜鳥|Sunbird|Flowerpecker|啄花/i, "食蜜鳥類：體型嬌小、色彩鮮豔，常繞花叢穿梭。"],
    [/秧雞|Rail|Crake|Waterhen|Swamphen|Moorhen/i, "秧雞科：性隱密，常在草叢或蘆葦邊緣快速穿行。"],
    [/鸚鵡|Parakeet|Hanging-Parrot|鳳頭鸚鵡|Cockatoo/i, "鸚鵡科：飛行時常發出尖銳叫聲，成對或小群活動。"],
    [/夜鷹|Nightjar|Frogmouth/i, "夜行性鳥類：白天偽裝停棲，黃昏後才開始活動鳴叫。"],
    [/鵑|Cuckoo|Malkoha|Koel|Coucal/i, "杜鵑科：叫聲極具辨識度，體態修長、尾羽常上翹。"],
    [/椋鳥|Starling|Myna/i, "椋鳥科：常成群活動，適應力強，市區與農地都能見到。"],
    [/鶯|Warbler|Prinia|Cisticola|Tesia|Tailorbird/i, "鶯科／扇尾鶯科：體型細小好動，多在草叢或灌叢間穿梭。"],
    [/畫眉|Babbler|Fulvetta/i, "噪眉科：性隱密好群聚，常於林下灌叢翻找覓食。"],
    [/鸛|Stork|Adjutant/i, "鸛科：大型涉禽，常見於濕地上空盤旋或涉水覓食。"]
  ];
  for(const [re, note] of rules){ if(re.test(name)) return note; }
  return "仔細記錄牠的體型、顏色分布與叫聲特徵，回程後再對照圖鑑確認辨識。";
}

/* ---------------- 小工具：可重現的隨機挑選 ---------------- */
function hashSeed(str){
  let h = 1779033703 ^ str.length;
  for(let i=0;i<str.length;i++){
    h = Math.imul(h ^ str.charCodeAt(i), 3432918353);
    h = (h << 13) | (h >>> 19);
  }
  return function(){
    h = Math.imul(h ^ (h >>> 16), 2246822507);
    h = Math.imul(h ^ (h >>> 13), 3266489909);
    h ^= h >>> 16;
    return (h >>> 0) / 4294967296;
  };
}
function seededShuffle(arr, seed){
  const rand = hashSeed(seed);
  const a = arr.slice();
  for(let i=a.length-1;i>0;i--){
    const j = Math.floor(rand()*(i+1));
    [a[i],a[j]] = [a[j],a[i]];
  }
  return a;
}

/* ---------------- 狀態管理 ---------------- */
const LS_LEARNED = z => `wia_learned_${z}`;
const LS_START = "wia_start_date";
const LS_DAYOFFSET = "wia_day_offset";
const LS_ACTIVE_ZONE = "wia_active_zone";
const LS_RESHUFFLE = z => `wia_reshuffle_${z}`;

function getLearned(zone){
  try{ return JSON.parse(localStorage.getItem(LS_LEARNED(zone))||"[]"); }catch(e){ return []; }
}
function setLearned(zone, arr){
  localStorage.setItem(LS_LEARNED(zone), JSON.stringify(arr));
}
function toggleLearned(zone, name){
  const arr = getLearned(zone);
  const i = arr.indexOf(name);
  if(i>=0) arr.splice(i,1); else arr.push(name);
  setLearned(zone, arr);
}

function getStartDate(){
  let d = localStorage.getItem(LS_START);
  if(!d){
    d = new Date().toISOString().slice(0,10);
    localStorage.setItem(LS_START, d);
  }
  return d;
}
function todayStr(offsetDays){
  const start = new Date(getStartDate()+"T00:00:00");
  const real = new Date();
  const realOffset = Math.floor((real - start) / 86400000);
  const total = realOffset + offsetDays;
  const d = new Date(start.getTime() + total*86400000);
  return d.toISOString().slice(0,10);
}
function getDayOffset(){ return parseInt(localStorage.getItem(LS_DAYOFFSET)||"0",10); }
function setDayOffset(v){ localStorage.setItem(LS_DAYOFFSET, String(v)); }

function getActiveZone(){ return localStorage.getItem(LS_ACTIVE_ZONE) || "merapi"; }
function setActiveZone(z){ localStorage.setItem(LS_ACTIVE_ZONE, z); }

function getReshuffleSalt(zone, dateKey){
  const key = LS_RESHUFFLE(zone)+"_"+dateKey;
  return localStorage.getItem(key) || "0";
}
function bumpReshuffleSalt(zone, dateKey){
  const key = LS_RESHUFFLE(zone)+"_"+dateKey;
  const v = parseInt(localStorage.getItem(key)||"0",10) + 1;
  localStorage.setItem(key, String(v));
  return String(v);
}

/* ---------------- 選出今日三鳥 ---------------- */
function pickToday(zone){
  const dateKey = todayStr(getDayOffset());
  const list = ZONES[zone].list;
  const learned = getLearned(zone);
  const remaining = list.filter(n => !learned.includes(n));
  const pool = remaining.length >= 3 ? remaining : list;
  const salt = getReshuffleSalt(zone, dateKey);
  const shuffled = seededShuffle(pool, zone+"|"+dateKey+"|"+salt);
  return { picks: shuffled.slice(0,3), dateKey, allDone: remaining.length===0 };
}

/* ---------------- 渲染 ---------------- */
function updateCounts(){
  Object.keys(ZONES).forEach(z=>{
    const learned = getLearned(z).length;
    const total = ZONES[z].list.length;
    document.getElementById(z+"Count").textContent = `${learned} / ${total} 種已學會`;
  });
}

function updateProgressBar(zone){
  const learned = getLearned(zone).length;
  const total = ZONES[zone].list.length;
  const pct = Math.round((learned/total)*100);
  document.getElementById("progressZoneName").textContent = ZONES[zone].label;
  document.getElementById("progressZoneNum").textContent = `${learned} / ${total}`;
  document.getElementById("progressZoneFill").style.width = pct+"%";
  const wrap = document.getElementById("progressZoneWrap");
  wrap.className = "progress-wrap zone-"+zone+"-bg";
}

function renderCards(){
  const zone = getActiveZone();
  const { picks, dateKey, allDone } = pickToday(zone);
  document.getElementById("todayLabel").textContent = dateKey;
  document.getElementById("dateStr").textContent = dateKey;
  document.getElementById("dayNum").textContent = getDayOffset() + Math.floor((new Date() - new Date(getStartDate()+"T00:00:00"))/86400000) + 1;

  const container = document.getElementById("cards");
  container.innerHTML = "";

  if(allDone){
    container.innerHTML = `<div style="grid-column:1/-1;padding:30px;text-align:center;background:rgba(255,255,255,0.04);border-radius:14px;font-family:'Fraunces',serif;font-size:18px;">
      🎉 這個熱點的鳥種你都學過一輪了！繼續換一組複習，或切換到另一個熱點吧。</div>`;
    return;
  }

  const learned = getLearned(zone);

  picks.forEach(name=>{
    const isLearned = learned.includes(name);
    const card = document.createElement("div");
    card.className = "card zone-"+zone+(isLearned?" learned":"");

    const sci = sciNameOf(name);
    const searchKey = sci || name;
    // eBird 會擋掉自動化工具直接驗證物種代碼（robots.txt），
    // 所以這裡用「限定 ebird.org/species 網域」的搜尋，確保一定能連到正確頁面，不會因猜錯代碼而連結失敗。
    const ebirdLink = `https://www.google.com/search?q=${encodeURIComponent('site:ebird.org/species "'+searchKey+'"')}`;
    const photoLink = `https://www.google.com/search?tbm=isch&q=${encodeURIComponent(searchKey+' bird')}`;
    const xeno = `https://xeno-canto.org/explore?query=${encodeURIComponent(searchKey)}`;

    card.innerHTML = `
      <div class="card-inner">
        <div class="face front">
          <span class="card-tag">${ZONES[zone].icon} ${zone==='merapi' ? '火山林' : '紅樹林'}</span>
          <div class="card-name">${name}${sci ? `<span class="sci-name">${sci}</span>` : ""}</div>
          <div class="card-foot">
            <button class="btn btn-flip">翻面看筆記 →</button>
            <button class="btn btn-learn ${isLearned?'done':''}">${isLearned?'✓ 已認識':'我認識了'}</button>
          </div>
          <div class="stamp">已<br>觀察</div>
        </div>
        <div class="face back">
          <span class="card-tag">野外筆記</span>
          <div class="note">${fieldNote(name)}</div>
          <div class="linkrow">
            <a href="${ebirdLink}" target="_blank" rel="noopener">🔗 eBird物種頁</a>
            <a href="${photoLink}" target="_blank" rel="noopener">📷 照片</a>
            <a href="${xeno}" target="_blank" rel="noopener">🔊 叫聲</a>
          </div>
          <div class="card-foot">
            <button class="btn btn-flip">← 翻回正面</button>
          </div>
        </div>
      </div>
    `;

    const flips = card.querySelectorAll(".btn-flip");
    flips.forEach(b=> b.addEventListener("click", ()=> card.classList.toggle("flipped")));

    const learnBtn = card.querySelector(".btn-learn");
    learnBtn.addEventListener("click", (e)=>{
      e.stopPropagation();
      toggleLearned(zone, name);
      const nowLearned = getLearned(zone).includes(name);
      card.classList.toggle("learned", nowLearned);
      learnBtn.classList.toggle("done", nowLearned);
      learnBtn.textContent = nowLearned ? "✓ 已認識" : "我認識了";
      updateCounts();
      updateProgressBar(zone);
    });

    container.appendChild(card);
  });
}

function renderAll(){
  const zone = getActiveZone();
  document.querySelectorAll(".tab").forEach(t=>{
    t.classList.toggle("active", t.dataset.zone === zone);
  });
  updateCounts();
  updateProgressBar(zone);
  renderCards();
}

/* ---------------- 事件綁定 ---------------- */
document.querySelectorAll(".tab").forEach(tab=>{
  tab.addEventListener("click", ()=>{
    setActiveZone(tab.dataset.zone);
    renderAll();
  });
});

document.getElementById("btnReshuffle").addEventListener("click", ()=>{
  const zone = getActiveZone();
  const dateKey = todayStr(getDayOffset());
  bumpReshuffleSalt(zone, dateKey);
  renderCards();
});

document.getElementById("btnNextDay").addEventListener("click", ()=>{
  setDayOffset(getDayOffset()+1);
  renderAll();
});
document.getElementById("btnPrevDay").addEventListener("click", ()=>{
  setDayOffset(Math.max(getDayOffset()-1, -3650));
  renderAll();
});

getStartDate();
renderAll();
</script>
