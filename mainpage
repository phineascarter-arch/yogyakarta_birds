<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>野鳥手記 · 日惹｜泗水</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#101b1a;
    --bg-2:#0b1413;
    --paper:#f4ecda;
    --paper-2:#eee2c4;
    --paper-line:#d9cba3;
    --ink:#2b2018;
    --ink-soft:#5b4d3d;
    --merapi:#c1592f;
    --merapi-deep:#7a3319;
    --merapi-soft:#f0d9c9;
    --wonorejo:#2f8f7c;
    --wonorejo-deep:#1c5c50;
    --wonorejo-soft:#d7ece6;
    --gold:#d1a54e;
    --muted:#8a9a95;
    --radius:14px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:
      radial-gradient(1200px 600px at 15% -10%, rgba(193,89,47,0.10), transparent 60%),
      radial-gradient(1200px 700px at 90% 10%, rgba(47,143,124,0.12), transparent 55%),
      var(--bg);
    color:var(--paper);
    font-family:'IBM Plex Sans', sans-serif;
    min-height:100vh;
    padding:28px 16px 60px;
  }
  .wrap{max-width:920px;margin:0 auto;}

  /* header */
  header{
    display:flex;justify-content:space-between;align-items:flex-end;
    flex-wrap:wrap;gap:14px;
    border-bottom:1px solid rgba(244,236,218,0.18);
    padding-bottom:18px;margin-bottom:22px;
  }
  .title-block .eyebrow{
    font-family:'IBM Plex Mono', monospace;
    font-size:12px;letter-spacing:.14em;text-transform:uppercase;
    color:var(--gold);margin:0 0 6px;
  }
  h1{
    font-family:'Fraunces', serif;font-weight:600;
    font-size:clamp(28px,4.5vw,40px);
    margin:0;line-height:1.05;color:var(--paper);
  }
  h1 em{font-style:italic;font-weight:500;color:var(--gold);}
  .daybadge{
    font-family:'IBM Plex Mono', monospace;
    background:var(--bg-2);
    border:1px solid rgba(244,236,218,0.22);
    border-radius:999px;
    padding:8px 16px;font-size:13px;color:var(--paper);
    white-space:nowrap;
  }
  .daybadge b{color:var(--gold);font-weight:600;}

  /* zone tabs */
  .tabs{display:flex;gap:10px;margin-bottom:22px;flex-wrap:wrap;}
  .tab{
    flex:1 1 220px;
    cursor:pointer;
    border-radius:12px;
    padding:14px 16px;
    border:1px solid rgba(244,236,218,0.18);
    background:rgba(255,255,255,0.02);
    transition:all .18s ease;
    display:flex;align-items:center;gap:10px;
  }
  .tab .ic{font-size:22px;}
  .tab .txt b{display:block;font-size:15px;color:var(--paper);}
  .tab .txt span{display:block;font-size:12px;color:var(--muted);font-family:'IBM Plex Mono',monospace;}
  .tab.active{border-color:transparent;}
  .tab[data-zone="merapi"].active{background:linear-gradient(135deg, var(--merapi), var(--merapi-deep));}
  .tab[data-zone="wonorejo"].active{background:linear-gradient(135deg, var(--wonorejo), var(--wonorejo-deep));}
  .tab.active .txt b, .tab.active .txt span{color:#fff;}

  /* today section */
  .today-head{
    display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:8px;
    margin-bottom:14px;
  }
  .today-head h2{
    font-family:'Fraunces', serif;font-weight:600;font-size:20px;margin:0;color:var(--paper);
  }
  .today-head .datestr{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--muted);}

  .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
  @media (max-width:760px){.cards{grid-template-columns:1fr;}}

  .card{
    perspective:1200px;height:260px;
  }
  .card-inner{
    position:relative;width:100%;height:100%;
    transform-style:preserve-3d;
    transition:transform .55s cubic-bezier(.4,.2,.2,1);
    border-radius:var(--radius);
  }
  .card.flipped .card-inner{transform:rotateY(180deg);}
  .face{
    position:absolute;inset:0;
    border-radius:var(--radius);
    backface-visibility:hidden;
    background:var(--paper);
    color:var(--ink);
    padding:18px;
    display:flex;flex-direction:column;
    box-shadow:0 10px 24px rgba(0,0,0,.28);
    border:1px solid var(--paper-line);
  }
  .face.back{transform:rotateY(180deg);background:var(--paper-2);}

  .card-tag{
    font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.06em;
    text-transform:uppercase;padding:3px 9px;border-radius:999px;
    display:inline-flex;align-self:flex-start;margin-bottom:10px;
  }
  .zone-merapi .card-tag{background:var(--merapi-soft);color:var(--merapi-deep);}
  .zone-wonorejo .card-tag{background:var(--wonorejo-soft);color:var(--wonorejo-deep);}

  .card-name{
    font-family:'Fraunces', serif;font-weight:600;font-size:20px;line-height:1.25;
    flex:1;display:flex;flex-direction:column;justify-content:center;gap:6px;
  }
  .sci-name{
    font-family:'Fraunces', serif;font-weight:500;font-style:italic;font-size:13px;
    color:var(--ink-soft);
  }
  .card-foot{display:flex;gap:8px;margin-top:10px;}
  .btn{
    font-family:'IBM Plex Sans',sans-serif;font-size:12.5px;font-weight:600;
    border:none;border-radius:8px;padding:9px 10px;cursor:pointer;
    flex:1;text-align:center;transition:transform .12s ease, opacity .12s ease;
  }
  .btn:active{transform:scale(.96);}
  .btn-flip{background:rgba(43,32,24,0.08);color:var(--ink);}
  .btn-learn{background:var(--ink);color:var(--paper);}
  .btn-learn.done{background:var(--gold);color:#3a2a08;}

  .note{font-size:13px;line-height:1.5;color:var(--ink-soft);flex:1;}
  .linkrow{display:flex;gap:6px;margin-top:10px;}
  .linkrow a{
    flex:1;text-align:center;font-size:10.5px;font-family:'IBM Plex Mono',monospace;
    text-decoration:none;padding:7px 3px;border-radius:8px;
    border:1px solid var(--paper-line);color:var(--ink-soft);
    white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
  }
  .linkrow a:hover{background:rgba(43,32,24,0.06);}

  .stamp{
    position:absolute;top:10px;right:10px;
    width:52px;height:52px;border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    font-family:'IBM Plex Mono',monospace;font-weight:600;font-size:10px;
    border:2px solid;transform:rotate(-14deg) scale(0);
    opacity:0;transition:all .35s cubic-bezier(.2,1.4,.4,1);
    text-align:center;line-height:1.1;letter-spacing:.03em;
  }
  .zone-merapi .stamp{color:var(--merapi);border-color:var(--merapi);}
  .zone-wonorejo .stamp{color:var(--wonorejo);border-color:var(--wonorejo);}
  .card.learned .stamp{transform:rotate(-14deg) scale(1);opacity:.9;}

  /* controls */
  .controls{display:flex;gap:10px;margin-top:20px;flex-wrap:wrap;}
  .ctrl-btn{
    font-family:'IBM Plex Mono',monospace;font-size:13px;
    background:rgba(255,255,255,0.04);border:1px solid rgba(244,236,218,0.2);
    color:var(--paper);padding:10px 16px;border-radius:10px;cursor:pointer;
  }
  .ctrl-btn:hover{background:rgba(255,255,255,0.09);}

  /* progress */
  .progress-wrap{margin-top:30px;padding-top:20px;border-top:1px solid rgba(244,236,218,0.18);}
  .progress-label{display:flex;justify-content:space-between;font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--muted);margin-bottom:8px;}
  .progress-bar{height:8px;border-radius:999px;background:rgba(255,255,255,0.08);overflow:hidden;}
  .progress-fill{height:100%;border-radius:999px;transition:width .4s ease;}
  .zone-merapi-bg .progress-fill{background:linear-gradient(90deg,var(--merapi),var(--gold));}
  .zone-wonorejo-bg .progress-fill{background:linear-gradient(90deg,var(--wonorejo),var(--gold));}

  footer{margin-top:40px;text-align:center;font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--muted);}
</style>
</head>
